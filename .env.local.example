# String de conexão com PostgreSQL do Supabase
# Formato: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
# Use a connection string do modo "Transaction" (porta 6543) ou "Session" (porta 5432)
DATABASE_URL=postgresql://postgres:senha@db.xxxxx.supabase.co:5432/postgres

# Segredo para assinatura dos tokens JWT
# Gere com: openssl rand -base64 32
# Mínimo 32 caracteres aleatórios
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio-minimo-32-chars
